# GreyNoise API key (get free key at https://viz.greynoise.io)
# Leave empty and set MOCK_MODE=true to run with demo data (no key needed)
GREYNOISE_API_KEY=""

# Demo mode: returns realistic fake data for all 13 transforms (no API key needed)
MOCK_MODE=false

# URL of greynoise-api microservice (used by transforms service in Docker)
# Leave empty to call GreyNoise API directly
GREYNOISE_API_URL=""

# Server ports
PORT=8080
GREYNOISE_API_PORT=8090
UI_PORT=3000

# Gin mode: debug | release | test
GIN_MODE=release

# HTTP timeout for GreyNoise API requests (seconds)
REQUEST_TIMEOUT_SECONDS=30

# PostgreSQL connection string for saved graphs
# Docker: set automatically via docker-compose environment
# Local: run postgres and set this to your connection string
DATABASE_URL=postgres://maltego:maltego@localhost:5432/maltego?sslmode=disable
